#!/bin/sh

# Power menu options
options=(
  "έΠ╗ Shutdown"
  "ΎΑη Reboot"
  "ΎΑμ Lock"
  "ΎΗΗ Suspend"
  "ΎΓΜ Logout"
  "ΎΑΞ Cancel"
)

# Show Rofi with two columns, no input bar, and large font
choice="$(printf '%s\n' "${options[@]}" | rofi -dmenu \
  -p 'Power menu' \
  -no-custom \
  -filter "" \
  -theme-str '
    entry {
      enabled: false;
    }
    listview {
      spacing: 10px;
      lines: 7;
      columns: 2;
    }
    element {
      padding: 10px;
      horizontal-align: 0.5;
    }
    mainbox {
      children: [listview];
    }
    window {
      width: 350px;
      height: 215px;
      border: 2px;
    }
  ')"

case "$choice" in
  "έΠ╗ Shutdown")
    systemctl poweroff
    ;;
  "ΎΑη Reboot")
    systemctl reboot
    ;;
  "ΎΑμ Lock")
    if command -v gtklock >/dev/null; then
      gtklock
    elif command -v hyprlock >/dev/null; then
      hyprlock
    elif command -v i3lock >/dev/null; then
      i3lock
    elif command -v betterlockscreen >/dev/null; then
      betterlockscreen -l
    else
      notify-send "No lock utility found."
    fi
    ;;
  "ΎΗΗ Suspend")
    systemctl suspend
    ;;
  "ΎΓΜ Logout")
    if [[ "$XDG_SESSION_TYPE" == "wayland" ]]; then
      if command -v hyprctl >/dev/null; then
        hyprctl dispatch exit
      elif command -v swaymsg >/dev/null; then
        swaymsg exit
      fi
    else
      pkill -KILL -u "$USER"
    fi
    ;;
  "ΎΑΞ Cancel")
    exit 0
    ;;
esac
